---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    /* Banana amber primary */
    --aw-color-primary: rgb(217 119 6);
    --aw-color-secondary: rgb(180 83 9);
    /* Jungle emerald accent */
    --aw-color-accent: rgb(5 150 105);

    --aw-color-text-heading: rgb(28 25 23);
    --aw-color-text-default: rgb(41 37 36);
    --aw-color-text-muted: rgb(41 37 36 / 66%);
    --aw-color-bg-page: rgb(255 251 235);

    --aw-color-bg-page-dark: rgb(20 14 4);

    ::selection {
      background-color: rgb(254 215 170);
      color: rgb(28 25 23);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(245 158 11);
    --aw-color-secondary: rgb(217 119 6);
    --aw-color-accent: rgb(16 185 129);

    --aw-color-text-heading: rgb(254 252 232);
    --aw-color-text-default: rgb(245 245 244);
    --aw-color-text-muted: rgb(245 245 244 / 66%);
    --aw-color-bg-page: rgb(20 14 4);

    ::selection {
      background-color: rgb(180 83 9);
      color: rgb(254 252 232);
    }
  }
</style>
