---
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->

  <Hero
    tagline="About KnowledgeMonkey"
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'A clutter of sticky notes — the chaos before KnowledgeMonkey',
    }}
  >
    <Fragment slot="title">
      We are giving structure to <br />
      <span class="text-accent dark:text-white">your conversations with AI</span>.
    </Fragment>

    <Fragment slot="subtitle">
      KnowledgeMonkey is on a mission to turn the brilliant, scattered, easily-forgotten chats you have with AI into a
      living second brain — one you can talk to, reorganize, share and own forever.
    </Fragment>
  </Hero>

  <!-- Stats ****************** -->

  <Stats
    title="A small troop, a big mission"
    stats={[
      { title: 'Platforms', amount: '3' },
      { title: 'LLMs supported', amount: '10+' },
      { title: 'Languages spoken by the team', amount: '7' },
      { title: 'Cups of coffee per shipped feature', amount: '∞' },
    ]}
  />

  <!-- Steps2 — Why ****************** -->

  <Steps2
    title="Why we built it"
    subtitle="We were having genius conversations with AI every day — and losing every one of them. So we built the place we wished existed."
    items={[
      {
        title: 'AI conversations are gold',
        description:
          'The way you learn, plan, brainstorm and decide has changed forever. The artefacts of that thinking deserve a home.',
      },
      {
        title: 'Linear chat is the wrong shape',
        description:
          'Threads vanish. Search is brittle. There is no map, no tree, no way to compose what you have learned into something bigger.',
      },
      {
        title: 'You should own your knowledge',
        description:
          'No vendor lock-in. Export everything as plain text. Take your second brain wherever you go.',
      },
    ]}
  />

  <!-- Steps2 — Principles ****************** -->

  <Steps2
    title="What we believe"
    subtitle="Six principles that shape every decision we make."
    isReversed={true}
    callToAction={{
      text: 'Get started — free',
      href: 'https://app.knowledgemonkey.com',
    }}
    items={[
      {
        title: 'AI-native, not AI-bolted-on',
        description: 'Every feature is designed assuming an LLM is in the loop. Voice, search, structure — all of it.',
        icon: 'tabler:robot',
      },
      {
        title: 'Hands-free is a first-class citizen',
        description:
          'Walking, driving, washing dishes — the best ideas show up everywhere. Your brain should travel with you.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Free should mean free',
        description:
          'The core experience is free forever. We make money when you choose to use our cloud LLMs or work in a team.',
        icon: 'tabler:gift',
      },
      {
        title: 'Your data stays yours',
        description: 'Export everything as Markdown / TXT / CSV any time. No drama, no migration tax.',
        icon: 'tabler:lock-open',
      },
      {
        title: 'Pick your own LLM',
        description: 'You should never be married to one model. Switch between GPT, Claude, Perplexity and more.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Built to be shared',
        description: 'Solo brain, study group, classroom, company — KnowledgeMonkey scales with how you collaborate.',
        icon: 'tabler:share-3',
      },
    ]}
  />

  <!-- Features2 ************** -->

  <Features2
    title="Where to find us"
    tagline="Get in touch"
    columns={2}
    items={[
      {
        title: 'Email',
        description: 'hello@knowledgemonkey.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Community',
        description: 'Join the troop on our community forum and Discord — link coming soon.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- CallToAction *********** -->

  <CallToAction
    title="Ready to give your AI conversations a home?"
    subtitle="Free forever. Web, iOS and Android. Bring your own LLM, or use ours."
    actions={[
      {
        variant: 'primary',
        text: 'Start free',
        href: 'https://app.knowledgemonkey.com',
        target: '_blank',
        icon: 'tabler:rocket',
      },
    ]}
  />
</Layout>
