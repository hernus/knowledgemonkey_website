---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <!-- HeroText ******************* -->

  <HeroText
    tagline="Contact"
    title="Say hi to the troop."
    subtitle="Bug reports, feature wishes, pricing questions, hello-just-because — they all find a friendly home here."
  />

  <ContactUs
    id="form"
    title="Drop us a message"
    subtitle="Most messages get a reply within one business day. For quick answers, the FAQs on the homepage cover the basics."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
    ]}
    textarea={{
      label: 'How can we help?',
    }}
    disclaimer={{
      label:
        'By submitting this form you agree to our Privacy Policy. We use your details only to reply to you.',
    }}
    description="We typically respond within 24 hours, Monday to Friday."
  />

  <!-- Features2 ************** -->

  <Features2
    title="Other ways to reach us"
    items={[
      {
        title: 'General questions',
        description:
          'Wondering what KnowledgeMonkey can do, or how a feature works? Drop us a line and a real human will reply.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Pro & Teams',
        description:
          'Thinking about Pro or rolling KnowledgeMonkey out to a team or class? We are happy to walk you through it.',
        icon: 'tabler:users',
      },
      {
        title: 'Bug reports',
        description:
          'Spotted something weird? Tell us what happened, what you expected, and which platform you were on. We are quick to fix.',
        icon: 'tabler:bug',
      },
      {
        title: 'Email',
        description: 'hello@knowledgemonkey.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Press',
        description: 'press@knowledgemonkey.com',
        icon: 'tabler:news',
      },
      {
        title: 'Security',
        description: 'security@knowledgemonkey.com',
        icon: 'tabler:shield-lock',
      },
    ]}
  />
</Layout>
