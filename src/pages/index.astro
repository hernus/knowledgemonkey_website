---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

import brainHeroImage from '~/assets/images/brain3.png';
import thinkingImage from '~/assets/images/thinking2.png';
import aiBakedInImage from '~/assets/images/AI_baked_in.png';
import stepsImage from '~/assets/images/steps.png';

const metadata = {
  title: 'KnowledgeMonkey — Your AI-native second brain',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->

  <Hero
    tagline="Web · iOS · Android · Free to start"
    actions={[
      {
        variant: 'primary',
        text: 'Get started — free',
        href: 'https://app.knowledgemonkey.ai',
        target: '_blank',
        icon: 'tabler:rocket',
      },
      { text: 'See how it works', href: '#use-cases', icon: 'tabler:player-play' },
    ]}
    image={{
      src: brainHeroImage,
      width: brainHeroImage.width,
      height: brainHeroImage.height,
      alt: 'KnowledgeMonkey — your AI-native second brain',
      class: 'mx-auto rounded-md w-auto h-auto max-h-[600px]',
    }}
  >
    <Fragment slot="title">
      Your <span class="text-accent">second brain</span>,<br />
      built for <span class="text-accent">AI</span>.
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        <span class="font-semibold">KnowledgeMonkey</span> is the AI-native place to capture, organize and converse
        with everything you learn.</span
      >
      <span class="block mb-1 sm:hidden font-bold text-amber-600">Capture. Organize. Talk to it.</span>
      Talk hands-free, switch between GPT, Claude or Perplexity, and turn scattered chats into notes, courses, books
      and study material you actually keep.
    </Fragment>
  </Hero>

  <!-- Note ******************* -->

  <Note
    title="Built for AI from the ground up:"
    description="Give structure to the conversations you have with AI."
  />

  <!-- Features *************** -->

  <Features
    id="features"
    tagline="Features"
    title="Everything an AI-native brain needs"
    subtitle="Capture by voice. Organize visually. Search semantically. Take it everywhere — and own every byte."
    items={[
      {
        title: 'Talk to it, hands-free',
        description:
          'Drive, walk, cook — capture ideas and have full back-and-forth conversations with your knowledge base, no keyboard required.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Choose your LLM',
        description:
          'Plug into GPT, Claude, Perplexity and many more. Pick the right model for the job — or bring your own API key.',
        icon: 'tabler:robot',
      },
      {
        title: 'AI-searchable knowledge chunks',
        description:
          'Your knowledge is broken into semantic chunks. No matter how big it gets, the AI always finds the right bits.',
        icon: 'tabler:search',
      },
      {
        title: 'Tree, mind map, or list',
        description:
          'Reorganize the same knowledge as a tree, a mind map, or a simple list — whichever way your brain prefers.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Use it from inside ChatGPT',
        description:
          'Already living in ChatGPT? Hook KnowledgeMonkey in and let it remember everything for you across sessions.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'No data lock-in, ever',
        description:
          'Export your entire brain as Markdown, plain text or CSV any time. It is your knowledge — we just give it a great home.',
        icon: 'tabler:download',
      },
    ]}
  />

  <!-- Content (Problem framing) **************** -->

  <Content
    isReversed
    tagline="The problem"
    title="AI conversations vanish. Your knowledge shouldn't."
    items={[
      {
        title: 'You ask, you learn, you forget',
        description:
          'Brilliant chats with AI scroll off the screen. A week later you cannot find that genius answer about your business idea.',
      },
      {
        title: 'No structure, no recall',
        description:
          'Linear chat threads were never designed to be a knowledge base. There is no shape, no index, no map.',
      },
      {
        title: 'KnowledgeMonkey solidifies it',
        description:
          'Every insight becomes a chunk. Chunks become trees, maps and projects. Your AI conversations finally compound.',
      },
    ]}
    image={{
      src: thinkingImage,
      width: thinkingImage.width,
      height: thinkingImage.height,
      alt: 'Person thinking — knowledge from AI chats should not disappear',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        We give structure to your AI conversations.
      </h3>
      Stop losing the best parts of every chat.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Use Cases — Flagship Four **************** -->

  <Features2
    id="use-cases"
    title="What people build with KnowledgeMonkey"
    subtitle="Four flagship use cases — and a thousand more your monkey brain will invent."
    tagline="Use cases"
    items={[
      {
        title: 'Capture & organize notes from AI',
        description:
          'Every great answer becomes a saved chunk. Tag it, link it, drop it into a project — your AI chats finally stay put.',
        icon: 'tabler:notes',
      },
      {
        title: 'Build your own training courses',
        description:
          'Spin up a course like "Nutrition 101" — one hour, ten short lessons. Listen while you walk, chat at the end of each chapter, edit on the fly.',
        icon: 'tabler:school',
      },
      {
        title: 'Study for exams',
        description:
          'Drop your notes in, let the AI quiz you, generate flashcards, and explain the bits you got wrong — all in one place.',
        icon: 'tabler:book-2',
      },
      {
        title: 'Write a book on the go',
        description:
          'Dictate a chapter on a walk, restructure it into a tree, let the AI tighten the prose, export to Markdown when you ship.',
        icon: 'tabler:writing',
      },
      {
        title: 'Draft blog posts',
        description:
          'Capture the spark in voice, expand it with AI, slot it into your content tree, publish to your favourite platform.',
        icon: 'tabler:article',
      },
      {
        title: 'Package & share knowledge projects',
        description:
          'Bundle a topic into a shareable project. Let others read it, remix it, contribute back — or keep it private. Up to you.',
        icon: 'tabler:share-3',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Steps — How it works ****************** -->

  <Steps
    title="From idea to organized knowledge — in four steps."
    items={[
      {
        title: 'Step 1: <span class="font-medium">Capture</span>',
        description:
          'Tap, type or talk. Drop in a YouTube link, a paste from ChatGPT, a voice memo. Anything becomes a knowledge chunk.',
        icon: 'tabler:microphone',
      },
      {
        title: 'Step 2: <span class="font-medium">Organize</span>',
        description:
          'Flip between tree, mind map and list. Drag chunks into projects. Let the AI suggest the structure for you.',
        icon: 'tabler:sitemap',
      },
      {
        title: 'Step 3: <span class="font-medium">Talk to it</span>',
        description:
          'Hands-free chats with your own brain. Quiz yourself, draft a chapter, listen to a lesson — pick your favourite LLM.',
        icon: 'tabler:message-chatbot',
      },
      {
        title: 'Ship & share',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: stepsImage,
      alt: 'From capture to share — your knowledge in clear steps',
    }}
  />

  <!-- Content — Built for AI ************ -->

  <Content
    isReversed
    isAfterContent
    tagline="AI-native, end to end"
    title="Not bolted-on AI. Born with it."
    items={[
      {
        title: 'Multi-model by design',
        description:
          'Switch between GPT, Claude, Perplexity and others per project — or per question. The right brain for the right job.',
      },
      {
        title: 'Semantic everything',
        description:
          'Every chunk is embedded and indexed. Search by meaning, not keywords. Scale to thousands of notes without losing the thread.',
      },
      {
        title: 'Voice as a first-class input',
        description:
          'Hands-free conversations are not a feature. They are how the product was designed from day one.',
      },
      {
        title: 'Generate, edit, restructure with AI',
        description:
          'Let AI rewrite a lesson, condense a chapter, or turn a tree into a mind map — all from inside the app.',
      },
    ]}
    image={{
      src: aiBakedInImage,
      width: aiBakedInImage.width,
      height: aiBakedInImage.height,
      alt: 'AI baked in — KnowledgeMonkey is AI-native from the ground up',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-amber-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Latest Blog ******* -->

  <BlogLatestPosts
    title="From the troops"
    information={`Product updates, deep dives on AI-native knowledge, and walkthroughs of real KnowledgeMonkey projects — from quick notes to full training courses.`}
  />

  <!-- FAQs ******************* -->

  <FAQs
    title="Frequently asked questions"
    subtitle="Everything you need to know before you swing in."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Is KnowledgeMonkey really free?',
        description:
          'Yes. The core app — capturing, organizing, voice chat with your own knowledge, exports — is free forever. Pro and Teams plans add cloud LLM credits, premium voices and advanced collaboration.',
      },
      {
        title: 'Which LLMs can I use?',
        description:
          'GPT (OpenAI), Claude (Anthropic), Perplexity, and a growing list of others. Pick per project, per question, or bring your own API key on the Free plan.',
      },
      {
        title: 'How does the hands-free voice mode work?',
        description:
          'Tap once and start talking. KnowledgeMonkey transcribes you live, talks back through high-quality voices, and saves anything worth keeping straight into your knowledge base — perfect for walks, drives or workouts.',
      },
      {
        title: 'What devices does it work on?',
        description:
          'Desktop web, iOS and Android. Your knowledge syncs across all three so you can capture an idea on the move and refine it at your desk.',
      },
      {
        title: 'Can I export my data?',
        description:
          'Anytime. Download everything as Markdown, plain text or CSV. No data lock-in — you own your brain.',
      },
      {
        title: 'How does sharing work?',
        description:
          'Bundle any set of chunks into a project. Share it as read-only, let trusted collaborators contribute, or keep it private. Great for teams, study groups, or publishing knowledge to the world.',
      },
    ]}
  />

  <!-- CallToAction *********** -->

  <CallToAction
    actionsLayout="vertical"
    actions={[
      {
        variant: 'primary',
        text: 'Get started — free',
        href: 'https://app.knowledgemonkey.ai',
        target: '_blank',
        icon: 'tabler:rocket',
      },
      {
        text: 'Download for iOS',
        href: '#',
        icon: 'tabler:brand-apple',
      },
      {
        text: 'Download for Android',
        href: '#',
        icon: 'tabler:brand-android',
      },
    ]}
  >
    <Fragment slot="title">
      Your AI conversations,<br class="block sm:hidden" /> finally <span class="sm:whitespace-nowrap text-accent">remembered</span>.
    </Fragment>

    <Fragment slot="subtitle">
      Free forever core. Works on web, iOS and Android. Bring your own LLM, or use ours.
    </Fragment>
  </CallToAction>
</Layout>
