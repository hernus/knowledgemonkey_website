---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing',
};
---

<Layout metadata={metadata}>
  <!-- HeroText ******************* -->

  <HeroText
    tagline="Pricing"
    title="Free forever core. Pro when you need more."
    subtitle="Capture, organize and converse with your knowledge for free, on every platform. Upgrade only if you want premium cloud LLMs, advanced collaboration, or team workspaces."
  />

  <!-- Pricing ******************* -->

  <Prices
    title="Pick your plan"
    subtitle="Start free. No credit card. Switch any time."
    prices={[
      {
        title: 'Free',
        subtitle: 'Everything you need to get going',
        price: 0,
        period: 'forever',
        items: [
          { description: 'Unlimited notes & knowledge chunks' },
          { description: 'Tree, mind map and list views' },
          { description: 'Hands-free voice capture & chat' },
          { description: 'Web, iOS and Android' },
          { description: 'Bring your own LLM API key (GPT, Claude, Perplexity…)' },
          { description: 'Export everything as Markdown / TXT / CSV' },
        ],
        callToAction: {
          target: '_blank',
          text: 'Start free',
          href: 'https://app.knowledgemonkey.ai',
        },
      },
      {
        title: 'Pro',
        subtitle: 'For builders, students and creators',
        price: 12,
        period: 'per month',
        items: [
          { description: 'Everything in Free' },
          { description: 'Cloud LLM credits included (no API key needed)' },
          { description: 'Premium voices for hands-free mode' },
          { description: 'Unlimited shareable knowledge projects' },
          { description: 'Priority sync across devices' },
          { description: 'Email support' },
        ],
        callToAction: {
          target: '_blank',
          text: 'Go Pro',
          href: 'https://app.knowledgemonkey.ai',
        },
        hasRibbon: true,
        ribbonTitle: 'most popular',
      },
      {
        title: 'Teams',
        subtitle: 'For study groups, classrooms and small companies',
        price: 24,
        period: 'per user / month',
        items: [
          { description: 'Everything in Pro' },
          { description: 'Shared team workspaces' },
          { description: 'Granular permissions on projects & chunks' },
          { description: 'Centralized billing & admin' },
          { description: 'SSO (coming soon)' },
          { description: 'Priority support' },
        ],
        callToAction: {
          target: '_blank',
          text: 'Talk to us',
          href: '/contact',
        },
      },
    ]}
  />

  <!-- Features3 ************** -->

  <Features3
    title="What's included on every plan"
    subtitle="The core of KnowledgeMonkey is free, on every device, forever."
    columns={2}
    items={[
      {
        title: 'No data lock-in',
        description: 'Export your full brain at any time as Markdown, TXT or CSV. Take it with you, always.',
        icon: 'tabler:download',
      },
      {
        title: 'AI-searchable knowledge',
        description: 'Every chunk is semantically indexed. Find anything by meaning, not keywords.',
        icon: 'tabler:search',
      },
      {
        title: 'Multi-LLM support',
        description: 'Switch between GPT, Claude, Perplexity and more — per project or per question.',
        icon: 'tabler:robot',
      },
      {
        title: 'Hands-free everywhere',
        description: 'Voice-first capture and conversation, on web, iOS and Android.',
        icon: 'tabler:microphone',
      },
      {
        title: 'ChatGPT integration',
        description: 'Plug KnowledgeMonkey into ChatGPT and let it remember everything across sessions.',
        icon: 'tabler:plug-connected',
      },
      {
        title: 'Sharing & collaboration',
        description: 'Bundle chunks into projects. Share read-only, or invite contributors. Up to you.',
        icon: 'tabler:share-3',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <!-- FAQs ******************* -->

  <FAQs
    title="Pricing FAQs"
    subtitle="Real answers to real questions about plans, billing and what stays free."
    columns={1}
    items={[
      {
        title: 'Is the Free plan really free forever?',
        description:
          "Yes. The Free plan is unlimited and stays free. The only thing it does not include is cloud LLM credits — bring your own API key on Free, or upgrade to Pro to use ours.",
      },
      {
        title: "What's the difference between Free and Pro?",
        description:
          'Free gives you the entire core product on every platform — but you provide your own LLM API key. Pro removes that step by including cloud LLM credits, premium voices, advanced sharing and priority sync.',
      },
      {
        title: 'Can I cancel any time?',
        description:
          'Yep. Cancel from the app in two taps. Your account drops back to Free and your data stays exactly where it is.',
      },
      {
        title: 'Do you offer a student discount?',
        description:
          'We do — and it is generous. Email us from a student address and we will sort you out.',
      },
      {
        title: 'How does Teams billing work?',
        description:
          'Teams is billed per active seat per month, with one consolidated invoice. Add and remove members from the admin panel any time.',
      },
      {
        title: 'What payment methods do you accept?',
        description:
          'All major credit and debit cards, Apple Pay and Google Pay. App Store and Play Store billing for mobile subscriptions.',
      },
    ]}
  />

  <!-- CallToAction *********** -->

  <CallToAction
    title="Try it free. Upgrade when (and if) you need to."
    subtitle="No credit card required to get started. Your knowledge is yours forever."
    actions={[
      {
        variant: 'primary',
        text: 'Start free',
        href: 'https://app.knowledgemonkey.ai',
        target: '_blank',
        icon: 'tabler:rocket',
      },
    ]}
  />
</Layout>
